# Rust
/target/
**/*.rs.bk
Cargo.lock

# macOS
.DS_Store
*.swp

# IDE
.idea/
.vscode/
*.xcodeproj/xcuserdata/
*.xcworkspace/xcuserdata/

# Build artifacts
*.dylib
*.so
*.a
*.dll

# Swift Package Manager
.build/
build/
.swiftpm/
Package.resolved

# Xcode
xcuserdata/
DerivedData/
*.xccheckout
*.moved-aside
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
*.xcodeproj/project.xcworkspace/
*.xcodeproj/xcshareddata/

# XcodeGen generated projects (app-level)
apps/*/*.xcodeproj/

# UniFFI generated code and build artifacts
**/generated/
**/frameworks/
**/*.xcframework/
**/*RustCore/
# Tests under app-embedded Packages/ are built into the app target and
# shouldn't be tracked separately. Top-level packages/*/Tests/ (SPM
# package tests) ARE tracked — earlier `**/Packages/*/Tests/` rule was
# too broad and silently dropped them.
apps/*/Packages/*/Tests/

# Environment
.env
.env.local

# Claude Code
.claude/

# AI Assistant configs
.agent/
.agents/
.continue/
.gemini/

# Temp files
*.txt.tmp
apps/t.txt

# Non-standard in-tree DerivedData (use Xcode's global DerivedData instead)
DerivedData/
